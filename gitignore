# TorBox Manager — .gitignore

# ---------------------------------------------------------------------------
# SENSITIVE — never commit these
# ---------------------------------------------------------------------------

# User config contains the TorBox API key
config.json

# ---------------------------------------------------------------------------
# GENERATED AT RUNTIME — no value in tracking these
# ---------------------------------------------------------------------------

# App log file
TorBox_Manager_Log.txt

# Partial downloads left behind by interrupted DownloadWorker
*.part

# ---------------------------------------------------------------------------
# PYTHON
# ---------------------------------------------------------------------------

# Virtual environment created by launch.bat
venv/

# Compiled bytecode
__pycache__/
*.py[cod]
*.pyo

# Distribution / packaging (not used here but good practice)
build/
dist/
*.egg-info/
.eggs/

# ---------------------------------------------------------------------------
# WINDOWS
# ---------------------------------------------------------------------------

# Thumbnail cache
Thumbs.db
ehthumbs.db

# Windows shortcut files (user-specific)
*.lnk

# Windows folder metadata
desktop.ini

# ---------------------------------------------------------------------------
# EDITORS / IDEs
# ---------------------------------------------------------------------------

# VS Code
.vscode/

# PyCharm
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace
